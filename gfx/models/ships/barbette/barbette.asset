pdxmesh = {
	name = "barbette_mesh"
	file = "barbette.mesh"

	animation = { id = "idle" 			type = "barbette_idle.anim" }
	#animation = { id = "move_start" 	type = "barbette_move_start.anim" }
	#animation = { id = "moving" 		type = "barbette_moving.anim" }
	#animation = { id = "port_idle"  	type = "barbette_idle.anim" }
	#animation = { id = "death" 			type = "barbette_idle.anim" }
	#animation = { id = "combat_fire" 	type = "barbette_combat_fire.anim" }
	#animation = { id = "combat_nofire" 	type = "barbette_combat_nofire.anim" }

	scale = 1.3

	meshsettings = {
		name = "barbette_LOD0"
		index = 0
		texture_diffuse = "barbette_diffuse.dds"
		texture_normal = "barbette_normal.dds"
		texture_specular = "barbette_properties.dds"
		texture = { file = "barbette_unique.dds" index = 5 }
		texture = { file = "barbette_color.dds" index = 6 }
		shader = "standard_usercolor_ship"
		shader_file = "gfx/FX/pdxmesh.shader"
	}
	meshsettings = {
		name = "barbette_LOD0"
		index = 1
		texture_diffuse = "null_diffuse.dds"
		texture_normal = "null_normal.dds"
		texture_specular = "null_gloss.dds"
		shader = "flag_ship"
		shader_file = "gfx/FX/pdxmesh.shader"
	}
}

entity = {
	name = "barbette"
	pdxmesh = "barbette_mesh"
	
	locator = { name = "combat_effect" position = { 0 0 0 } rotation = { 0 0 0 } }
	
	default_state = "idle"
	state = {
		name = "idle"
    	animation = "idle"
		event = { time = 0 node = "ship_main" particle = "units/ship_idle_wave_01_effect" keep_particle = yes trigger_once = no }
		event = { time = 3 node = "ship_main" particle = "units/ship_idle_wave_01_effect" keep_particle = yes trigger_once = no }
		start_event = { trigger_once = yes sound = { soundeffect = "event:/SFX/Animations/Ships/Generic/sfx_anim_ship_generic_idle" } keep_sound = yes }
    }
	state = {
		name = "port_idle"
    	animation = "port_idle"
    }
}

entity = {
	name = "greek_gfx_barbette"
	clone = "barbette"
}

