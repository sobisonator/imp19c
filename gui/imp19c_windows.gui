								size = { 2 2 }
							}
							blockoverride "White_buttons" 
							{
								button_close = {
									onclick = "[GetVariableSystem.Set( 'supranational_window', 'close' )]"
									tooltip = "CLOSE"
									shortcut = "close_window"
								}
							}
						}
					}
				}
				flowcontainer = {
					visible = "[GetVariableSystem.HasValue('supranational_tabs', 'diplomatic_plays')]"
