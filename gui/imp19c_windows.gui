# OPEN WITH: gui.createwidget gui/imp19c_windows.gui example_window
# Just replace "example window" with the name of your widget

base_window = {
	name = "example_window" #name used in console command to open widget
    gfxtype = windowgfx
    parentanchor = center
    size = { 650 550 }
    vbox = {
        using = MainWindowHeaderBoxCentered

        blockoverride "Title_text" { text = "example_window" }

        vbox = {
            layoutpolicy_vertical = expanding
        }

    }
    button_close = {
        onclick = "[ExecuteConsoleCommand('GUI.ClearWidgets example_window')]"
        tooltip = "CLOSE"
        parentanchor = top|right
        position = { -7 10}
    }
}

types PeaceWindows
{
	type alternative_peace_window = base_window {
	size = { 980 712 }
	position = { 68 0 }
	parentanchor = bottom
	name = "alternative_peace_window" # name used in console command to open widget
	movable = no
	alwaystransparent = no
	state = {
		name = _show
	}
	state = {
		name = _hide
		start_sound = {
			soundeffect = "event:/SFX/UI/Generic/2.0/sfx_ui_window_tab_close"
		}
		on_start = "[GetVariableSystem.Clear( 'destablize_up' )]"
		on_start = "[GetVariableSystem.Clear( 'reparations_up' )]"
		on_start = "[GetVariableSystem.Clear( 'delegitimize_up' )]"
		on_start = "[GetVariableSystem.Clear( 'steal_knowledge_up' )]"
		on_start = "[GetVariableSystem.Clear( 'extort_population_up' )]"
		#duration = 0.2
	}
	flowcontainer = {
		direction = vertical
		widget = {
			size = { 980 48 }
			using = MainWindowHeaderBoxCenteredNew
			blockoverride "Title_text" { text = "[Player.MakeScope.Var('peace_window_active_war').War.GetName]" }
			blockoverride "White_buttons" 
			{
				button_close = {
					name = "close_alternative_peace_window"
					datacontext = "[GetScriptedGui('remove_war_lists_button')]"
					onclick = "[GetVariableSystem.Set( 'alternative_peace_window', 'closed' )]"
					onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Player.MakeScope ).End )]"
					tooltip = "CLOSE"
				}
			}
		}
		flowcontainer = {
			margin = { 10 0 }
			spacing = 10
			widget = {
				size = { 80 80 }
				new_country_flag = {
					datacontext = "[GetScriptedGui('select_peace_recipient_country_defender')]"
					blockoverride "Size" { size = { 80 80 } }
					tooltip = "[Player.MakeScope.Var('peace_window_active_war').War.GetDefenderWarLeader.GetName]"
					blockoverride "On_click"
					{
						onclick = "[GetVariableSystem.Set( 'recipient_country_defender', Player.MakeScope.Var('peace_window_active_war').War.GetDefenderWarLeader.GetTag )]"
						onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Player.MakeScope.Var('peace_window_active_war').War.GetDefenderWarLeader.MakeScope ).AddScope('war', Player.MakeScope.Var('peace_window_active_war').War.MakeScope).End )]"
					}
					blockoverride "Flag" {
						datacontext = "[Player.MakeScope.Var('peace_window_active_war').War.GetDefenderWarLeader]"
						texture = "[Country.AccessCoatOfArms.GetTexture('(int32)120','(int32)120')]"
						frame = "[Country.AccessCoatOfArms.GetFrame('(int32)120','(int32)120')]"
						framesize = { 120 120 }
					}
					blockoverride "FlagOverlord" {
						datacontext = "[Player.MakeScope.Var('peace_window_active_war').War.GetDefenderWarLeader]"
						texture = "[Country.GetOverlord.AccessCoatOfArms.GetTexture('(int32)120','(int32)120')]"
						frame = "[Country.GetOverlord.AccessCoatOfArms.GetFrame('(int32)120','(int32)120')]"
						framesize = { 120 120 }
					}
					onmousehierarchyenter = "[SetHighlightCountry(Player.MakeScope.Var('peace_window_active_war').War.GetDefenderWarLeader.GetCountry)]"
					onmousehierarchyleave = "[ClearHighlightColors]"
				}
				#icon = {
				#	using = black_background
				#	size = { 100% 52 }
				#	parentanchor = vcenter
				#	alpha = 0.5
				#	visible = "[Not(GetVariableSystem.HasValue( 'recipient_country_defender', Player.MakeScope.Var('peace_window_active_war').War.GetDefenderWarLeader.GetTag ))]"
				#}
			}
			flowcontainer = {
				ignoreinvisible = yes
				margin_top = 10
				#POSITIVE WARSCORE BAR
				fixed_size_progressbar_war_score = {

					blockoverride "ProgressColor" { using = green_color }
					visible = "[GreaterThan_int32( Player.MakeScope.Var('peace_window_active_war').War.GetWarScore, '(int32)0' )]"
					blockoverride "Icon" { texture = "gfx/interface/icons/shared_icons/warscore_cost.dds" }
					blockoverride "Value" { value = "[IntToFloat( Player.MakeScope.Var('peace_window_active_war').War.GetWarScore )]" }
					blockoverride "Text" {
						position = { 0 -5 }
						text = "[Player.MakeScope.Var('peace_window_active_war').War.GetWarScore]"
					}
				}
				#NEGATIVE WARSCORE BAR
				fixed_size_progressbar_war_score = {
					blockoverride "ProgressColor" { using = red_color }
					visible = "[LessThanOrEqualTo_int32( Player.MakeScope.Var('peace_window_active_war').WarScore, '(int32)0' )]"
					blockoverride "Icon" { texture = "gfx/interface/icons/shared_icons/warscore_cost.dds" }
					blockoverride "Value" { value = "[IntToFloat( Abs_int32(Player.MakeScope.Var('peace_window_active_war').War.GetWarScore) )]" }
					blockoverride "Text" {
						position = { 0 -5 }
						text = "[Player.MakeScope.Var('peace_window_active_war').War.GetWarScore]"
					}
				}
			}
			widget = {
				size = { 80 80 }
				new_country_flag = {
					datacontext = "[GetScriptedGui('select_peace_recipient_country_attacker')]"
					blockoverride "Size" { size = { 80 80 } }
					tooltip = "[Player.MakeScope.Var('peace_window_active_war').War.GetAttackerWarLeader.GetName]"
					blockoverride "On_click"
					{
						onclick = "[GetVariableSystem.Set( 'recipient_country_defender', Player.MakeScope.Var('peace_window_active_war').War.GetDefenderWarLeader.GetTag )]"
						onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Player.MakeScope.Var('peace_window_active_war').War.GetDefenderWarLeader.MakeScope ).AddScope('war', Player.MakeScope.Var('peace_window_active_war').War.MakeScope).End )]"
					}
					blockoverride "Flag" {
						datacontext = "[Player.MakeScope.Var('peace_window_active_war').War.GetAttackerWarLeader]"
						texture = "[Country.AccessCoatOfArms.GetTexture('(int32)120','(int32)120')]"
						frame = "[Country.AccessCoatOfArms.GetFrame('(int32)120','(int32)120')]"
						framesize = { 120 120 }
					}
					blockoverride "FlagOverlord" {
						datacontext = "[Player.MakeScope.Var('peace_window_active_war').War.GetAttackerWarLeader]"
						texture = "[Country.GetOverlord.AccessCoatOfArms.GetTexture('(int32)120','(int32)120')]"
						frame = "[Country.GetOverlord.AccessCoatOfArms.GetFrame('(int32)120','(int32)120')]"
						framesize = { 120 120 }
					}
					onmousehierarchyenter = "[SetHighlightCountry(Player.MakeScope.Var('peace_window_active_war').War.GetAttackerWarLeader.GetCountry)]"
					onmousehierarchyleave = "[ClearHighlightColors]"
				}
				#icon = {
				#	using = black_background
				#	size = { 100% 52 }
				#	parentanchor = vcenter
				#	alpha = 0.5
				#	visible = "[Not(GetVariableSystem.HasValue( 'recipient_country_attacker', Player.MakeScope.Var('peace_window_active_war').War.GetAttackerWarLeader.GetTag ))]"
				#}
			}
		}
		flowcontainer = {
			margin = { 10 0 }
			spacing = 10
			scrollarea = {
				size = { 80 530 }
				scrollbarpolicy_horizontal = always_off
				using = VerticalScrollAreaCutOff
				scrollbar_vertical = {
					using = VerticalScrollBar
				}
				
				scrollwidget = {
					dynamicgridbox = {
						parentanchor = hcenter
						datamodel = "[Player.MakeScope.GetList('war_defender_list')]"
						item = {
							widget = {
								size = { 56 44 }
								new_country_flag = {
									datacontext = "[GetScriptedGui('select_peace_recipient_country_defender')]"
									blockoverride "Size" { size = { 56 56 } }
									parentanchor = vcenter
									tooltip = "[Scope.Country.GetName]"
									blockoverride "On_click"
									{
										onclick = "[GetVariableSystem.Set( 'recipient_country_defender', Scope.GetCountry.GetTag )]"
										onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Scope.Country.MakeScope ).AddScope('war', Player.MakeScope.Var('peace_window_active_war').War.MakeScope).End )]"
									}
									blockoverride "Flag" {
										datacontext = "[Scope.Country]"
										texture = "[Country.AccessCoatOfArms.GetTexture('(int32)56','(int32)56')]"
										frame = "[Country.AccessCoatOfArms.GetFrame('(int32)56','(int32)56')]"
										framesize = { 56 56 }
									}
									blockoverride "FlagOverlord" {
										datacontext = "[Scope.Country]"
										texture = "[Country.GetOverlord.AccessCoatOfArms.GetTexture('(int32)56','(int32)56')]"
										frame = "[Country.GetOverlord.AccessCoatOfArms.GetFrame('(int32)56','(int32)56')]"
										framesize = { 56 56 }
									}
									onmousehierarchyenter = "[SetHighlightCountry(Scope.GetCountry)]"
									onmousehierarchyleave = "[ClearHighlightColors]"
								}
								icon = {
									using = black_background
									size = { 100% 100% }
									alpha = 0.5
									visible = "[Not(GetVariableSystem.HasValue( 'recipient_country_defender', Scope.GetCountry.GetTag ))]"
								}
							}
						}
					}
				}
			}
			flowcontainer = {
				direction = vertical
				spacing = 10
				ignoreinvisible = yes
				flowcontainer = {
					direction = vertical
					margin_widget = {
						size = { 780 48 }
						icon = {
							position = { -10 42 }
							using = brighten_red_background
							size = { 10 2 }
						}
						icon = {
							position = { -10 42 }
							using = brighten_red_background
							size = { 2 498 }
						}
						icon = {
							position = { 10 42 }
							using = brighten_red_background
							size = { 10 2 }
							parentanchor = right
						}
						icon = {
							position = { 10 42 }
							using = brighten_red_background
							size = { 2 498 }
							parentanchor = right
						}
						hbox = { 
							spacing = 2
							margin_top = 4
							category_tab = {
								blockoverride "MinSize" { size = { @mincategorybuttonwidth @mincategorybuttonheight } }
								blockoverride "MaxSize" { size = { @maxcategorybuttonwidth @maxcategorybuttonheight } }
								blockoverride "MinVisible" { visible = "[And( Not( GetVariableSystem.HasValue('peace_tabs', 'province')), GetVariableSystem.Exists('diplomatic_tabs'))]" }
								blockoverride "MaxVisible" { visible = "[Or( GetVariableSystem.HasValue('peace_tabs', 'province'), Not( GetVariableSystem.Exists('diplomatic_tabs') ) )]" }
								######## Shared Overrides
								blockoverride "Center_text" { text = "peace_tab_province" }
								blockoverride "Icon" { visible = no }
								######## Small Button Overrides
								blockoverride "ClickFunction"
								{
									onclick = "[GetVariableSystem.Set('peace_tabs', 'province')]"
								}
							}  
							category_tab = {
								blockoverride "Enabled" { enabled = "[Not(And( Not( EqualTo_int32( DiplomaticView.GetTargetCountry.GetId, Player.GetId ) ), Not(DiplomaticView.GetTargetCountry.IsBarbarian) ))]" }
								blockoverride "MinSize" { size = { @mincategorybuttonwidth @mincategorybuttonheight } }
								blockoverride "MaxSize" { size = { @maxcategorybuttonwidth @maxcategorybuttonheight } }
								blockoverride "MinVisible" { visible = "[Not( GetVariableSystem.HasValue('peace_tabs', 'other'))]" }
								blockoverride "MaxVisible" { visible = "[GetVariableSystem.HasValue('peace_tabs', 'other')]" }
								######## Shared Overrides
								blockoverride "Center_text" { text = "peace_tab_other" }
								blockoverride "Icon" { visible = no }
								######## Small Button Overrides
								blockoverride "ClickFunction"
								{
									onclick = "[GetVariableSystem.Set('peace_tabs', 'other')]"
								}
							}
						}
					}
					flowcontainer = {
						textbox = {
							parentanchor = hcenter
							using = BaseFontM
							using = Default_FontColor
							fontsize = 20
							size = { 390 30 }
							align = center
							text = "peace_def_concessions"
						}
						textbox = {
							parentanchor = hcenter
							using = BaseFontM
							using = Default_FontColor
							fontsize = 20
							size = { 390 30 }
							align = center
							text = "peace_attack_concessions"
						}
					}
				}
				flowcontainer = {
					spacing = 10
					margin = { 5 0 }
					visible = "[GetVariableSystem.HasValue( 'peace_tabs', 'province' )]"
					PeaceNegotiationBlock = {
						blockoverride "country_list" {
							datamodel = "[Player.MakeScope.GetList('war_defender_list')]"
						}
						blockoverride "country_item_buttoncontext" {
							datacontext = "[GetScriptedGui('select_defender_country')]"
						}
						blockoverride "country_list_datamodel" {
							datamodel = "[Player.MakeScope.GetList('war_defender_list')]"
						}
						blockoverride "select_country_context" {
							datacontext = "[GetScriptedGui('select_defender_country')]"
						}
						blockoverride "state_list" {
							datamodel = "[Scope.Country.MakeScope.GetList('states_available_from_defender')]"
						}
						blockoverride "state_item_buttoncontext" {
							datacontext = "[GetScriptedGui('select_state_from_defender')]"
						}
						blockoverride "state_item_rightclick_script" {
							onrightclick = "[GetScriptedGui('select_state_from_defender_rightclick').Execute( GuiScope.SetRoot( Scope.State.MakeScope ).AddScope('war', Player.MakeScope.Var('peace_window_active_war').War.MakeScope ).End )]"
						}
						blockoverride "province_list" {
							datamodel = "[Scope.GetState.MakeScope.GetList('provinces_available_from_defender')]"
						}
						blockoverride "province_item_buttoncontext" {
							datacontext = "[GetScriptedGui('select_province_from_defender')]"
						}
					}
					PeaceNegotiationBlock = {
						blockoverride "country_list" {
							datamodel = "[Player.MakeScope.GetList('war_attacker_list')]"
						}
						blockoverride "country_item_buttoncontext" {
							datacontext = "[GetScriptedGui('select_attacker_country')]"
						}
						blockoverride "country_list_datamodel" {
							datamodel = "[Player.MakeScope.GetList('war_defender_list')]"
						}
						blockoverride "select_country_context" {
							datacontext = "[GetScriptedGui('select_defender_country')]"
						}
						blockoverride "state_list" {
							datamodel = "[Scope.Country.MakeScope.GetList('states_available_from_attacker')]"
						}
						blockoverride "state_item_buttoncontext" {
							datacontext = "[GetScriptedGui('select_state_from_defender')]"
						}
						blockoverride "state_item_rightclick_script" {
							onrightclick = "[GetScriptedGui('select_state_from_attacker_rightclick').Execute( GuiScope.SetRoot( Scope.State.MakeScope ).AddScope('war', Player.MakeScope.Var('peace_window_active_war').War.MakeScope ).End )]"
						}
						blockoverride "province_list" {
							datamodel = "[Scope.GetState.MakeScope.GetList('provinces_available_from_attacker')]"
						}
						blockoverride "province_item_buttoncontext" {
							datacontext = "[GetScriptedGui('select_province_from_attacker')]"
						}
					}
				}
				flowcontainer = {
					spacing = 10
					margin = { 5 0 }
					visible = "[GetVariableSystem.HasValue( 'peace_tabs', 'other' )]"
					PeaceNegotiationBlockOther = {	
					}
					PeaceNegotiationBlockOther = {
					}
				}
				flowcontainer = {
					spacing = 5
					parentanchor = hcenter
					icon_and_text = {
						size = { 110 32 }
						blockoverride "Icon" { 
							texture = "gfx/interface/icons/shared_icons/warscore_cost.dds" 
						}
						blockoverride "Text" { 
							text = "[GuiScope.SetRoot( Player.MakeScope.Var('peace_window_active_war').War.MakeScope ).ScriptValue('WARSCORE_cost_total_attacker')|1]" # TODO: Make this Custom text that's conditional on if the viewer is attacker or defender
							using = BaseFontL
							using = Default_FontColor
							#visible = yes # Var is attacker > 0
						}
						tooltip = "WRITE_ME"
						position = { -30 -184 }
						parentanchor = bottom|right
					}
					icon_and_text = {
						size = { 110 32 }
						blockoverride "Icon" { 
							texture = "gfx/interface/icons/shared_icons/aggressive_expansion.dds" 
						}
						blockoverride "Text" { 
							text = "[Player.MakeScope.Var('aggressive_expansion_cost').GetValue|0]" 
							using = BaseFontL
							using = Default_FontColor
						}
						tooltip = "peace_tt_aggressive_expansion_cost"
						position = { -30 -148 }
						parentanchor = bottom|right
					}
				}
				text_button_square = {
					parentanchor = hcenter
					size = { 225 28 }
					name = "accept_button"
					datacontext = "[GetScriptedGui('send_final_offer_button')]"
					blockoverride "Center_text" { text = "offer_peace" }
					blockoverride "On_click" { 
						onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Player.MakeScope.Var('peace_window_active_war').War.MakeScope ).AddScope('player', Player.MakeScope).End )]"
						onclick = "[Player.MakeScope.Var('peace_window_active_war').OnClose]"
						enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Player.MakeScope.Var('peace_window_active_war').War.MakeScope ).AddScope('player', Player.MakeScope).End )]"
					}
					tooltip = "[Player.MakeScope.Var('peace_window_active_war').War.MakeScope.GetVariable('war_scope_standin').GetProvince.Custom('peace_ai_acceptance_loc')]" # TODO: Put this in custom loc and break it down by the factors that make up acceptance value
					blockoverride "ClickSound" { clicksound = "event:/SFX/UI/Diplomacy/sfx_ui_diplomacy_peace_minor" }
				}
				scrollarea = {
					parentanchor = hcenter
					size = { 760 75 }
					name = "description_scrollarea"
					scrollbarpolicy_horizontal = always_off
					
					using = NoninteractableBG
					blockoverride "Margins" { 
						margin = { 4 7 } 
						margin_bottom = 10
					}
					scrollbar_vertical = {
						using = VerticalScrollBar
					}
					
					scrollwidget = {
						textbox = {
							text = "WAR_SCORE_COST_CURRENT_TT"
							multiline = yes
							autoresize = yes
							minimumsize = { 750 0 }
							maximumsize = { 750 -1 }
							using = BaseFontS
							using = Default_FontColor
							elide = right
							fontsize = 16
							margin = { 5 0 }
							#parentanchor = center
						}
					}
				}
			}
			scrollarea = {
				size = { 80 530 }
				scrollbarpolicy_horizontal = always_off
				using = VerticalScrollAreaCutOff
				scrollbar_vertical = {
					using = VerticalScrollBar
				}
				
				scrollwidget = {
					dynamicgridbox = {
						parentanchor = hcenter
						datamodel = "[Player.MakeScope.GetList('war_attacker_list')]"
						item = {
							widget = {
								size = { 56 44 }
								new_country_flag = {
									datacontext = "[GetScriptedGui('select_peace_recipient_country_attacker')]"
									blockoverride "Size" { size = { 56 56 } }
									parentanchor = vcenter
									tooltip = "[Scope.Country.GetName]"
									blockoverride "On_click"
									{
										onclick = "[GetVariableSystem.Set( 'recipient_country_attacker', Scope.GetCountry.GetTag )]"
										onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Scope.Country.MakeScope ).AddScope('war', Player.MakeScope.Var('peace_window_active_war').War.MakeScope).End )]"
									}
									blockoverride "Flag" {
										datacontext = "[Scope.Country]"
										texture = "[Country.AccessCoatOfArms.GetTexture('(int32)56','(int32)56')]"
										frame = "[Country.AccessCoatOfArms.GetFrame('(int32)56','(int32)56')]"
										framesize = { 56 56 }
									}
									blockoverride "FlagOverlord" {
										datacontext = "[Scope.Country]"
										texture = "[Country.GetOverlord.AccessCoatOfArms.GetTexture('(int32)56','(int32)56')]"
										frame = "[Country.GetOverlord.AccessCoatOfArms.GetFrame('(int32)56','(int32)56')]"
										framesize = { 56 56 }
									}
									onmousehierarchyenter = "[SetHighlightCountry(Scope.GetCountry)]"
									onmousehierarchyleave = "[ClearHighlightColors]"
								}
								icon = {
									using = black_background
									size = { 100% 100% }
									alpha = 0.5
									visible = "[Not(GetVariableSystem.HasValue( 'recipient_country_attacker', Scope.GetCountry.GetTag ))]"
								}
							}
						}
					}
				}
			}
		}
	}
	##POSITIVE WARSCORE BAR
	#flowcontainer = {
