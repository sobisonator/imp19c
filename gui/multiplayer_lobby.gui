				using = tooltip_se
			}
			blockoverride "Icon"
			{
				size = { 24 24 }
				using = white_background
				texture = "gfx/interface/icons/shared_icons/military_experience.dds"
			}
		}
		icon_button_square = {
			size = { 32 32 }
			visible = "[Not(LobbyView.ShouldShowEnabledMods)]"
			blockoverride "On_click" 
			{ 
				enabled = "[LobbyView.HasEnabledMods]"
				onclick = "[LobbyView.ToggleShowEnabledMods]"
				tooltip = "JOMINI_MULTIPLAYER_GUI_ENABLED_MODS"
				using = tooltip_se
			}
			blockoverride "Icon"
			{
				size = { 24 24 }
				using = white_background
				texture = "gfx/interface/icons/shared_icons/military_experience.dds"
			}
		}
	}
	flowcontainer = {
		parentanchor = bottom
		position = { 340 0 }
		ignoreinvisible = yes
		state = {
			name = "show_mp_left_panel"
			animation = { position = { 340 0 } }
			bezier = { 0.44 1.11 0.74 0.91 }
			trigger_when = "[GetVariableSystem.HasValue('mp_left_panel', 'show')]"
			duration = 0.2
		}
		state = {
			name = "hide_mp_left_panel"
			animation = { position = { 40 0 } }
			bezier = { 0.44 0.2 0.74 0.91 }
			trigger_when = "[GetVariableSystem.HasValue('mp_left_panel', 'hide')]"
			duration = 0.2
		}
		sharp_base_window = {
			size = { 200 145 }
			visible = "[LobbyView.ShouldShowEnabledDLCs]"
			blockoverride "BackgroundGradient" { visible = no }
			flowcontainer = {
				margin = { 5 5 }
				direction = vertical
				spacing = 3
				sub_header = {
					size = { 190 32 }
					blockoverride "Title_text" { text = "JOMINI_MULTIPLAYER_GUI_ENABLED_DLCS" }
				}
				scrollarea = {
					size = { 185 100 }
					scrollbarpolicy_horizontal = always_off
					scrollbar_vertical = {
						using = VerticalScrollBar
					}
					
					scrollwidget = {
						flowcontainer = {
							datamodel = "[LobbyView.GetEnabledDLCs]"
							direction = vertical
							margin = { 3 0 }
							item = {
								textbox = {
									text = "[CString.GetString]"
									autoresize = yes
									using = BaseFontS
									using = Default_FontColor
								}
							}
						}
					}
				}
			}
		}
		sharp_base_window = {
			size = { 200 145 }
			visible = "[LobbyView.ShouldShowEnabledMods]"
			blockoverride "BackgroundGradient" { visible = no }
			flowcontainer = {
				margin = { 5 5 }
				direction = vertical
				spacing = 3
				sub_header = {
					size = { 190 32 }
					blockoverride "Title_text" { text = "JOMINI_MULTIPLAYER_GUI_ENABLED_MODS" }
				}
				scrollarea = {
					size = { 185 100 }
					scrollbarpolicy_horizontal = always_off
					scrollbar_vertical = {
						using = VerticalScrollBar
					}
					
					scrollwidget = {
						flowcontainer = {
							datamodel = "[LobbyView.GetEnabledMods]"
							direction = vertical
							margin = { 3 0 }
							item = {
								textbox = {
									text = "[CString.GetString]"
									autoresize = yes
									using = BaseFontS
									using = Default_FontColor
								}
							}
						}
					}
				}
			}
		}
	}
	widget = {
		size = { 400 40 }
		parentanchor = hcenter
		using = MainWindowHeaderBoxCenteredNew
		blockoverride "LineVisibility" { }
		blockoverride "Title_text" { text = "CURRENT_DATE" }
		blockoverride "White_buttons" { visible = no }
		tooltip = "THE_WORLD_TOOLTIP"
	}
	sharp_base_window = {
		size = { 400 100% }
		movable = no
		parentanchor = right
		layer = top
		visible = "[LobbyView.HasSelectedPlayable]"
		datacontext = "[LobbyView.GetSelectedPlayable.GetCountry]"
		flowcontainer = {
			margin = { 10 10 }
			new_country_banner = {
				blockoverride "Size" { size = { 192 192 } }
				parentanchor = vcenter
				blockoverride "On_click" { onclick = "[PanToCountry(Country.Self)]" }
				blockoverride "Flag" {
					texture = "[Country.AccessCoatOfArms.GetTexture('(int32)192','(int32)192')]"
					frame = "[Country.AccessCoatOfArms.GetFrame('(int32)192','(int32)192')]"
					framesize = { 192 192 }
				}
			}
		}
		flowcontainer = {
			margin = { 10 10 }
			parentanchor = bottom
			position = { 0 -2 }
			icon_button_square = {
				size = { 44 44 }
				visible = "[Not(GetVariableSystem.HasValue('mp_left_panel', 'hide'))]"
				blockoverride "On_click" 
				{ 
					onclick = "[LobbyView.ToggleObserve]"
					tooltip = "JOMINI_MULTIPLAYER_GUI_OBSERVE_TOOLTIP"
					using = tooltip_se
				}
				blockoverride "Icon"
				{
					size = { 28 28 }
					texture = "gfx/interface/icons/diplomatic_stances/trading_stance.dds"
				}
			}
			margin_widget = {
				size = { 336 44 }
				enabled = "[LobbyView.CanGoBack]"
				tooltip = "[LobbyView.GetGoBackToolTip]"
				frontend_button = {
					size = { 100% 100% }
					blockoverride "Text" { text = "JOMINI_MULTIPLAYER_GUI_START" }
					blockoverride "On_click" { 
						onclick = "[GetVariableSystem.Set('mp_start_screen', 'start')]"
					}
				}
			}
		}
	}
	flowcontainer = {
		position = { -398 0 }
		parentanchor = right|bottom
		margin = { 5 5 }
