@windowwidth = 1920
@windowheight = 1080

widget = {
	name = "lobbyview"
	size = { 100% 100% }

	widget = {
		size = { 100% 100% }
		filter_mouse = left|wheel|right
		alwaystransparent = no
		background = {
			shaderfile = "gfx/FX/pdxgui_default.shader"
			using = black_background
		}
		background = {
			shaderfile = "gfx/FX/pdxgui_default.shader"
			using = pattern_black_background_layer_01
			modify_texture = {
				texture = "gfx/interface/base_parts/background_x60bd_alpha_two_corner.dds"
				blend_mode = alphamultiply
				spriteType = Corneredtiled
				spriteborder = { 60 60 }
			}
		}
		background = {
			shaderfile = "gfx/FX/pdxgui_default.shader"
			using = pattern_black_background_layer_02
			modify_texture = {
				texture = "gfx/interface/base_parts/background_x60bd_alpha_two_corner.dds"
				blend_mode = alphamultiply
				spriteType = Corneredtiled
				spriteborder = { 60 60 }
			}
		}
		state = {
			name = show_mp_window
			on_start = "[PdxGuiWidget.Show]"
		}
		state = {
			name = hide_mp_window
			on_start = "[PdxGuiWidget.Hide]"
		}
		widget = {
			size = { 100% 100% }
			mp_select_tab = {
				visible = "[GetVariableSystem.HasValue('mp_select_tab', 'europe')]"
				blockoverride "map_texture" { texture = "gfx/interface/images/mp_select/maps/europe.png" }
				blockoverride "countries" {
					mp_select_country_map = {
						datacontext = "[GetCountry('GBR')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/GBR.png" }
					}
					mp_select_country_map = {
						datacontext = "[GetCountry('PRU')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/PRU.png" }
					}
					mp_select_country_map = {
						datacontext = "[GetCountry('RUS')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/RUS.png" }
					}
					mp_select_country_map = {
						datacontext = "[GetCountry('FRA')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/FRA.png" }
					}
					mp_select_country_map = {
						datacontext = "[GetCountry('NED')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/NED.png" }
					}
					mp_select_country_map = {
						datacontext = "[GetCountry('AUS')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/AUS.png" }
					}
					mp_select_country_map = {
						datacontext = "[GetCountry('SAR')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/SAR.png" }
					}
					mp_select_country_map = {
						datacontext = "[GetCountry('SPA')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/SPA.png" }
					}
				}
			}
			mp_select_tab = {
				visible = "[GetVariableSystem.HasValue('mp_select_tab', 'middle_east')]"
				blockoverride "map_texture" { texture = "gfx/interface/images/mp_select/maps/middle_east.png" }
				blockoverride "countries" {
					mp_select_country_map = {
						datacontext = "[GetCountry('TUR')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/TUR.png" }
					}
					mp_select_country_map = {
						datacontext = "[GetCountry('EGY')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/EGY.png" }
					}
				}
			}
			mp_select_tab = {
				visible = "[GetVariableSystem.HasValue('mp_select_tab', 'south_asia')]"
				blockoverride "map_texture" { texture = "gfx/interface/images/mp_select/maps/south_asia.png" }
				blockoverride "countries" {
					mp_select_country_map = {
						datacontext = "[GetCountry('EIC')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/EIC.png" }
					}
					mp_select_country_map = {
						datacontext = "[GetCountry('KHL')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/KHL.png" }
					}
				}
			}
			mp_select_tab = {
				visible = "[GetVariableSystem.HasValue('mp_select_tab', 'east_asia')]"
				blockoverride "map_texture" { texture = "gfx/interface/images/mp_select/maps/east_asia.png" }
				blockoverride "countries" {
					mp_select_country_map = {
						datacontext = "[GetCountry('CHI')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/CHI.png" }
					}
					mp_select_country_map = {
						datacontext = "[GetCountry('TKG')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/TKG.png" }
					}
				}
			}
			mp_select_tab = {
				visible = "[GetVariableSystem.HasValue('mp_select_tab', 'central_america')]"
				blockoverride "map_texture" { texture = "gfx/interface/images/mp_select/maps/central_america.png" }
				blockoverride "countries" {
					mp_select_country_map = {
						datacontext = "[GetCountry('VNZ')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/VNZ.png" }
					}
					mp_select_country_map = {
						datacontext = "[GetCountry('MEX')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/MEX.png" }
					}
				}
			}
			mp_select_tab = {
				visible = "[GetVariableSystem.HasValue('mp_select_tab', 'north_america')]"
				blockoverride "map_texture" { texture = "gfx/interface/images/mp_select/maps/north_america.png" }
				blockoverride "countries" {
					mp_select_country_map = {
						datacontext = "[GetCountry('USA')]"
						blockoverride "texture" { texture = "gfx/interface/images/mp_select/countries/USA.png" }
					}
				}
			}
			widget = {
				name = "3Dmodel"
				size = { @windowwidth @windowheight }
				parentanchor = center
				frame_select_window = {
					size = { 100% 100% }
				}
			}
		}
		mp_select_tab_top = {
			visible = "[GetVariableSystem.HasValue('mp_select_tab', 'europe')]"
			blockoverride "countries" {
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('GBR')]"
					blockoverride "position" { position = { 480 240 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/GBR.dds" }
				}
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('PRU')]"
					blockoverride "position" { position = { 810 275 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/PRU.dds" }
				}
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('RUS')]"
					blockoverride "position" { position = { 1200 200 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/RUS.dds" }
				}
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('FRA')]"
					blockoverride "position" { position = { 580 405 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/FRA.dds" }
				}
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('NED')]"
					blockoverride "position" { position = { 630 300 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/NED.dds" }
				}
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('AUS')]"
					blockoverride "position" { position = { 810 400 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/AUS.dds" }
				}
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('SAR')]"
					blockoverride "position" { position = { 675 490 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/SAR.dds" }
				}
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('SPA')]"
					blockoverride "position" { position = { 460 610 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/SPA.dds" }
				}
			}
		}
		mp_select_tab_top = {
			visible = "[GetVariableSystem.HasValue('mp_select_tab', 'middle_east')]"
			blockoverride "countries" {
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('TUR')]"
					blockoverride "position" { position = { 550 100 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/TUR.dds" }
				}
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('EGY')]"
					blockoverride "position" { position = { 570 330 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/TUR.dds" }
				}
			}
		}
		mp_select_tab_top = {
			visible = "[GetVariableSystem.HasValue('mp_select_tab', 'south_asia')]"
			blockoverride "countries" {
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('EIC')]"
					blockoverride "position" { position = { 450 420 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/EIC.dds" }
				}
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('KHL')]"
					blockoverride "position" { position = { 390 80 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/KHL.dds" }
				}
			}
		}
		mp_select_tab_top = {
			visible = "[GetVariableSystem.HasValue('mp_select_tab', 'east_asia')]"
			blockoverride "countries" {
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('CHI')]"
					blockoverride "position" { position = { 700 220 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/CHI.dds" }
				}
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('TKG')]"
					blockoverride "position" { position = { 1120 310 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/TKG.dds" }
				}
			}
		}
		mp_select_tab_top = {
			visible = "[GetVariableSystem.HasValue('mp_select_tab', 'central_america')]"
			blockoverride "countries" {
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('VNZ')]"
					blockoverride "position" { position = { 1070 505 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/VNZ.dds" }
				}
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('MEX')]"
					blockoverride "position" { position = { 450 280 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/MEX.dds" }
				}
			}
		}
		mp_select_tab_top = {
			visible = "[GetVariableSystem.HasValue('mp_select_tab', 'north_america')]"
			blockoverride "countries" {
				mp_select_country_map_coa = {
					datacontext = "[GetCountry('USA')]"
					blockoverride "position" { position = { 850 330 } }
					blockoverride "texture_coa" { texture = "gfx/interface/images/mp_select/coa/USA.dds" }
				}
			}
		}
	}
	sharp_base_window_clear = {
		size = { 300 100% }
		movable = no
		parentanchor = left
		visible = "[Not(GetVariableSystem.HasValue('mp_start_screen', 'start'))]"
		state = {
			name = "show_mp_left_panel"
			animation = { position = { 0 0 } }
			bezier = { 0.44 1.11 0.74 0.91 }
			trigger_when = "[GetVariableSystem.HasValue('mp_left_panel', 'show')]"
			duration = 0.2
		}
		state = {
			name = "hide_mp_left_panel"
			animation = { position = { -300 0 } }
			bezier = { 0.44 0.2 0.74 0.91 }
			trigger_when = "[GetVariableSystem.HasValue('mp_left_panel', 'hide')]"
			duration = 0.2
		}
		textbox = {
			text = "JOMINI_MULTIPLAYER_GUI_GAME_VERSION"
			tooltip = "JOMINI_MULTIPLAYER_GUI_GAME_VERSION_TOOLTIP"
			autoresize = yes
			using = BaseFontS
			using = Default_FontColor
			position = { 5 3 }
			alpha = 0.5
		}
		flowcontainer = {
			margin = { 10 0 }
			direction = vertical
			margin_top = 20
			textbox = {
				size = { 280 40 }
				align = center
				elide = right
				using = HeaderFont
				using = Highlight_FontColor
				fontsize_min = 14
				text = "SELECT_TITLE_SULLA_V"
			}
			flowcontainer = {
				ignoreinvisible = yes
				direction = vertical
				spacing = 5
				mp_any_country_button = {
					blockoverride "Text" { text = "mp_recommended_countries" }
					visible = no
					state = {
						name = show_mp_window
						on_start = "[PdxGuiWidget.Hide]"
					}
					state = {
						name = hide_mp_window
						on_start = "[PdxGuiWidget.Show]"
					}
					blockoverride "On_click" {
						onclick = "[PdxGuiTriggerAllAnimations('show_mp_window')]"
					}
				}
				mp_any_country_button = {
					blockoverride "Text" { text = "mp_any_country" }
					state = {
						name = show_mp_window
						on_start = "[PdxGuiWidget.Show]"
					}
					state = {
						name = hide_mp_window
						on_start = "[PdxGuiWidget.Hide]"
					}
					blockoverride "On_click" {
						onclick = "[PdxGuiTriggerAllAnimations('hide_mp_window')]"
						onclick = "[PanToCountry(LobbyView.GetSelectedPlayable.GetCountry.Self)]"
						#onclick = "[PanToCountry(GetCountry('GBR').Self)]"
					}
				}
				widget = { size = { 280 30 } }
				category_drop = {
					size = { 280 32 }
					blockoverride "Text" { text = "mp_select_tab_europe"  }
					blockoverride "On_click" { onclick = "[GetVariableSystem.Set('mp_select_tab', 'europe')]" }
					blockoverride "Right" { visible = "[GetVariableSystem.HasValue('mp_select_tab', 'europe')]" }
					blockoverride "Down" { visible = "[Not(GetVariableSystem.HasValue('mp_select_tab', 'europe'))]" }
				}
				flowcontainer = {
					visible = "[GetVariableSystem.HasValue('mp_select_tab', 'europe')]"
					direction = vertical
					spacing = 5
					mp_select_button = {
						datacontext = "[GetCountry('GBR')]"
					}
					mp_select_button = {
						datacontext = "[GetCountry('PRU')]"
					}
					mp_select_button = {
						datacontext = "[GetCountry('RUS')]"
					}
					mp_select_button = {
						datacontext = "[GetCountry('FRA')]"
					}
					mp_select_button = {
						datacontext = "[GetCountry('NED')]"
					}
					mp_select_button = {
						datacontext = "[GetCountry('AUS')]"
					}
					mp_select_button = {
						datacontext = "[GetCountry('SAR')]"
					}
					mp_select_button = {
						datacontext = "[GetCountry('SPA')]"
					}
				}
				category_drop = {
					size = { 280 32 }
					blockoverride "Text" { text = "mp_select_tab_middle_east"  }
					blockoverride "On_click" { onclick = "[GetVariableSystem.Set('mp_select_tab', 'middle_east')]" }
					blockoverride "Right" { visible = "[GetVariableSystem.HasValue('mp_select_tab', 'middle_east')]" }
					blockoverride "Down" { visible = "[Not(GetVariableSystem.HasValue('mp_select_tab', 'middle_east'))]" }
				}
				flowcontainer = {
					visible = "[GetVariableSystem.HasValue('mp_select_tab', 'middle_east')]"
					direction = vertical
					spacing = 5
					mp_select_button = {
						datacontext = "[GetCountry('TUR')]"
					}
					mp_select_button = {
						datacontext = "[GetCountry('EGY')]"
					}
				}
				category_drop = {
					size = { 280 32 }
					blockoverride "Text" { text = "mp_select_tab_south_asia"  }
					blockoverride "On_click" { onclick = "[GetVariableSystem.Set('mp_select_tab', 'south_asia')]" }
					blockoverride "Right" { visible = "[GetVariableSystem.HasValue('mp_select_tab', 'south_asia')]" }
					blockoverride "Down" { visible = "[Not(GetVariableSystem.HasValue('mp_select_tab', 'south_asia'))]" }
				}
				flowcontainer = {
					visible = "[GetVariableSystem.HasValue('mp_select_tab', 'south_asia')]"
					direction = vertical
					spacing = 5
					mp_select_button = {
						datacontext = "[GetCountry('EIC')]"
					}
					mp_select_button = {
						datacontext = "[GetCountry('KHL')]"
					}
				}
				category_drop = {
					size = { 280 32 }
					blockoverride "Text" { text = "mp_select_tab_east_asia"  }
					blockoverride "On_click" { onclick = "[GetVariableSystem.Set('mp_select_tab', 'east_asia')]" }
					blockoverride "Right" { visible = "[GetVariableSystem.HasValue('mp_select_tab', 'east_asia')]" }
					blockoverride "Down" { visible = "[Not(GetVariableSystem.HasValue('mp_select_tab', 'east_asia'))]" }
				}
				flowcontainer = {
					visible = "[GetVariableSystem.HasValue('mp_select_tab', 'east_asia')]"
					direction = vertical
					spacing = 5
					mp_select_button = {
						datacontext = "[GetCountry('CHI')]"
					}
					mp_select_button = {
						datacontext = "[GetCountry('TKG')]"
					}
				}
				category_drop = {
					size = { 280 32 }
					blockoverride "Text" { text = "mp_select_tab_central_america"  }
					blockoverride "On_click" { onclick = "[GetVariableSystem.Set('mp_select_tab', 'central_america')]" }
					blockoverride "Right" { visible = "[GetVariableSystem.HasValue('mp_select_tab', 'central_america')]" }
					blockoverride "Down" { visible = "[Not(GetVariableSystem.HasValue('mp_select_tab', 'central_america'))]" }
				}
				flowcontainer = {
					visible = "[GetVariableSystem.HasValue('mp_select_tab', 'central_america')]"
					direction = vertical
					spacing = 5
					mp_select_button = {
						datacontext = "[GetCountry('VNZ')]"
					}
					mp_select_button = {
						datacontext = "[GetCountry('MEX')]"
					}
				}
				category_drop = {
					size = { 280 32 }
					blockoverride "Text" { text = "mp_select_tab_north_america"  }
					blockoverride "On_click" { onclick = "[GetVariableSystem.Set('mp_select_tab', 'north_america')]" }
					blockoverride "Right" { visible = "[GetVariableSystem.HasValue('mp_select_tab', 'north_america')]" }
					blockoverride "Down" { visible = "[Not(GetVariableSystem.HasValue('mp_select_tab', 'north_america'))]" }
				}
				flowcontainer = {
					visible = "[GetVariableSystem.HasValue('mp_select_tab', 'north_america')]"
					direction = vertical
					spacing = 5
					mp_select_button = {
						datacontext = "[GetCountry('USA')]"
					}	
				}
			}
		}
		margin_widget = {
			size = { 280 44 }
			parentanchor = hcenter|bottom
			position = { 0 -12 }
			enabled = "[LobbyView.CanGoBack]"
			tooltip = "[LobbyView.GetGoBackToolTip]"
			frontend_button = {
				size = { 100% 100% }
				blockoverride "Text" { text = "BACK" }
				blockoverride "On_click" { 
					onclick = "[SetPreparationLobby('(bool)no')]"
					onclick = "[LobbyView.GoBack]"
					shortcut = "close_window"
				}
			}
		}
	}
	flowcontainer = {
		position = { 300 0 }
		margin = { 5 5 }
		direction = vertical
		ignoreinvisible = yes
		spacing = 5
		state = {
			name = "show_mp_left_panel"
			animation = { position = { 300 0 } }
			bezier = { 0.44 1.11 0.74 0.91 }
			trigger_when = "[GetVariableSystem.HasValue('mp_left_panel', 'show')]"
			duration = 0.2
		}
		state = {
			name = "hide_mp_left_panel"
			animation = { position = { 0 0 } }
			bezier = { 0.44 0.2 0.74 0.91 }
			trigger_when = "[GetVariableSystem.HasValue('mp_left_panel', 'hide')]"
			duration = 0.2
		}
		icon_button_square = {
			size = { 44 44 }
			visible = "[Not(GetVariableSystem.HasValue('mp_left_panel', 'hide'))]"
			blockoverride "On_click" 
			{ 
				onclick = "[GetVariableSystem.Set( 'mp_left_panel', 'hide' )]"
				tooltip = "hide_mp_left_panel"
				using = tooltip_se
			}
			blockoverride "Icon"
			{
				size = { 28 28 }
				using = white_background
				modify_texture = {
					texture = "gfx/interface/base_parts/left_arrow.dds"
					blend_mode = alphamultiply   
				}
			}
		}
		icon_button_square = {
			size = { 44 44 }
			visible = "[GetVariableSystem.HasValue('mp_left_panel', 'hide')]"
			blockoverride "On_click" 
			{ 
				onclick = "[GetVariableSystem.Set( 'mp_left_panel', 'show' )]"
				tooltip = "show_mp_left_panel"
				using = tooltip_se
			}
			blockoverride "Icon"
			{
				size = { 28 28 }
				using = white_background
				modify_texture = {
					texture = "gfx/interface/base_parts/right_arrow.dds"
					blend_mode = alphamultiply   
				}
			}
		}
		window = {
			movable = no
			visible = no
			using = mp_base_animation
			state = {
				name = show_mp_window
				on_start = "[PdxGuiWidget.Hide]"
			}
			state = {
				name = hide_mp_window
				on_start = "[PdxGuiWidget.Show]"
			}
			background = {
				shaderfile = "gfx/FX/pdxgui_default.shader"
				using = shadow_background
				margin = { 5 5 }
				alpha = 0.5
				modify_texture = {
					texture = "gfx/interface/base_parts/button_square_dropshadow_x16y16bd.dds"
					blend_mode = alphamultiply
					spriteType = corneredtiled
					spriteborder = { 8 8 }
				}
			}
			background = {
				shaderfile = "gfx/FX/pdxgui_default.shader"
				using = black_background
				#margin = { -3 -3 }
			}
			flowcontainer = {
				margin = { 3 3 }
				direction = vertical
				spacing = 2
				resizeparent = yes
				button = {
					shortcut = "map_mode_1"
					using = droptargetbutton
					blockoverride "IconTexture" { texture = "gfx/interface/icons/minimap/terrain.dds" } 
					onclick = "[SetMapMode('terrain')]"
					tooltip = "MAPMODE_TERRAIN"
