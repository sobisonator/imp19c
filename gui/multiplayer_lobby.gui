													blockoverride "On_click"
													{
														onclick = "[RelationDescItem.OnClick]"
													}
													blockoverride "Flag" {
														texture = "[Country.AccessCoatOfArms.GetTexture('(int32)32','(int32)32')]"
														frame = "[Country.AccessCoatOfArms.GetFrame('(int32)32','(int32)32')]"
														framesize = { 32 32 }
													}
													blockoverride "FlagOverlord" {
														texture = "[Country.GetOverlord.AccessCoatOfArms.GetTexture('(int32)32','(int32)32')]"
														frame = "[Country.GetOverlord.AccessCoatOfArms.GetFrame('(int32)32','(int32)32')]"
														framesize = { 32 32 }
													}
												}
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
		flowcontainer = {
			margin = { 10 10 }
			parentanchor = bottom
			position = { 0 -2 }
			icon_button_square = {
				size = { 44 44 }
				blockoverride "On_click" 
				{ 
					onclick = "[LobbyView.ToggleObserve]"
					tooltip = "JOMINI_MULTIPLAYER_GUI_OBSERVE_TOOLTIP"
					using = tooltip_se
				}
				blockoverride "Icon"
				{
					size = { 28 28 }
					texture = "gfx/interface/icons/diplomatic_stances/trading_stance.dds"
				}
			}
			margin_widget = {
				size = { 336 44 }
				enabled = "[LobbyView.CanGoBack]"
				tooltip = "[LobbyView.GetGoBackToolTip]"
				frontend_button = {
					size = { 100% 100% }
					blockoverride "Text" { text = "JOMINI_MULTIPLAYER_GUI_START" }
					blockoverride "On_click" { 
						onclick = "[GetVariableSystem.Set('mp_start_screen', 'start')]"
					}
				}
			}
		}
	}
	flowcontainer = {
		position = { -398 0 }
		parentanchor = right|bottom
		margin = { 5 5 }
		direction = vertical
		ignoreinvisible = yes
		icon_button_square = {
			size = { 44 44 }
			visible = "[Not(GetVariableSystem.HasValue('mp_game_configuration_panel', 'show'))]"
			blockoverride "On_click" 
			{ 
				onclick = "[GetVariableSystem.Set( 'mp_game_configuration_panel', 'show' )]"
				tooltip = "show_mp_game_configuration_panel"
				using = tooltip_se
			}
			blockoverride "Icon"
			{
				size = { 28 28 }
				using = white_background
				modify_texture = {
					texture = "gfx/interface/base_parts/settings.dds"
					blend_mode = alphamultiply   
				}
			}
		}
		icon_button_square = {
			size = { 44 44 }
			visible = "[GetVariableSystem.HasValue('mp_game_configuration_panel', 'show')]"
			blockoverride "On_click" 
			{ 
				onclick = "[GetVariableSystem.Set( 'mp_game_configuration_panel', 'hide' )]"
				tooltip = "hide_mp_game_configuration_panel"
				using = tooltip_se
			}
			blockoverride "Icon"
			{
				size = { 28 28 }
				using = white_background
				modify_texture = {
					texture = "gfx/interface/base_parts/settings.dds"
					blend_mode = alphamultiply   
				}
			}
		}
	}
	widget = {
		size = { 100% 100% }
		visible = "[Not(GameIsMultiplayer)]"
		mp_start_screen = { }
	}
}

