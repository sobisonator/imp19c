	flowcontainer = {
		parentanchor = bottom
		position = { 300 0 }
		margin = { 5 5 }
		direction = vertical
		ignoreinvisible = yes
		state = {
			name = "show_mp_left_panel"
			animation = { position = { 300 0 } }
			bezier = { 0.44 1.11 0.74 0.91 }
			trigger_when = "[GetVariableSystem.HasValue('mp_left_panel', 'show')]"
			duration = 0.2
		}
		state = {
			name = "hide_mp_left_panel"
			animation = { position = { 0 0 } }
			bezier = { 0.44 0.2 0.74 0.91 }
			trigger_when = "[GetVariableSystem.HasValue('mp_left_panel', 'hide')]"
			duration = 0.2
		}
