	flowcontainer = {
		parentanchor = bottom
		position = { 300 0 }
		margin = { 5 5 }
		direction = vertical
		ignoreinvisible = yes
		state = {
			name = "show_mp_left_panel"
			animation = { position = { 300 0 } }
			bezier = { 0.44 1.11 0.74 0.91 }
			trigger_when = "[GetVariableSystem.HasValue('mp_left_panel', 'show')]"
			duration = 0.2
		}
		state = {
			name = "hide_mp_left_panel"
			animation = { position = { 0 0 } }
			bezier = { 0.44 0.2 0.74 0.91 }
			trigger_when = "[GetVariableSystem.HasValue('mp_left_panel', 'hide')]"
			duration = 0.2
		}
		icon_button_square = {
			size = { 32 32 }
			visible = "[LobbyView.ShouldShowEnabledDLCs]"
			blockoverride "On_click" 
			{ 
				enabled = "[LobbyView.HasEnabledDLCs]"
				onclick = "[LobbyView.ToggleShowEnabledDLCs]"
				tooltip = "JOMINI_MULTIPLAYER_GUI_ENABLED_DLCS"
				using = tooltip_se
			}
			blockoverride "Icon"
			{
				size = { 24 24 }
				texture = "gfx/interface/icons/shared_icons/missing_dlc.dds"
			}
		}
		icon_button_square = {
			size = { 32 32 }
			visible = "[Not(LobbyView.ShouldShowEnabledDLCs)]"
			blockoverride "On_click" 
			{ 
				enabled = "[LobbyView.HasEnabledDLCs]"
				onclick = "[LobbyView.ToggleShowEnabledDLCs]"
				tooltip = "JOMINI_MULTIPLAYER_GUI_ENABLED_DLCS"
				using = tooltip_se
			}
			blockoverride "Icon"
			{
				size = { 24 24 }
				using = white_background
				texture = "gfx/interface/icons/shared_icons/missing_dlc.dds"
			}
		}
		widget = { size = { 32 5 } }
		icon_button_square = {
			size = { 32 32 }
			visible = "[LobbyView.ShouldShowEnabledMods]"
			blockoverride "On_click" 
			{ 
				enabled = "[LobbyView.HasEnabledMods]"
