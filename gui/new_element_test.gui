types TEST_ELEMENTS {
	type new_element_test_window = widget {
		size = { 100% 100% }
		filter_mouse = left|wheel|right
		alwaystransparent = no
		background = {
			shaderfile = "gfx/FX/pdxgui_default.shader"
			#using = white_background
			using = black_background
		}
		flowcontainer = {
			margin = { 10 10 }
			spacing = 20
			direction = vertical
			datacontext = "[GetCountry('FRA')]"
			flowcontainer = { # Europe - rectangular 3:2
				direction = vertical
				new_country_flag = {
					blockoverride "Size" { size = { 120 120 } }
				}
				textbox = {
					autoresize = yes
					parentanchor = hcenter
					using = BaseFontL
					text = "Europe"
				}
			}
			widget = {
				size = { 100 32 }
				#enabled = no
				background = {
					name = "Shadow"
					texture = "gfx/interface/base_parts/button_square_dropshadow_x16y16bd.dds"
					shaderfile = "gfx/FX/pdxgui_default.shader"
					spriteType = corneredtiled
					spriteborder = { 8 8 }
					margin = { 4 4 }
					alpha = 0.5
				}
			
				button = {
					name = "Button_Outline"
					using = red_background
					gfxtype = buttongfx
					size = { 100% 100% }
					alpha = 0.5
					block "On_click" { }
					block "Shortcut" { }
					background = {
						shaderfile = "gfx/FX/pdxgui_default.shader"
						using = portrait_x32y32bd_alpha
						using = beige_background
						modify_texture = {
							texture = "gfx/interface/base_parts/button_vignette.dds"
							blend_mode = alphamultiply
							spriteType = corneredtiled
							spriteborder = { 20 20 }
						}
					}
					margin_widget = {
						size = { 100% 100% }
						margin = { 3 3 }
						button = {
							gfxtype = buttongfx
							size = { 100% 100% }
							using = red_background
							using = portrait_x32y32bd_alpha
							alpha = 2.0
							background = {
								shaderfile = "gfx/FX/pdxgui_default.shader"
								using = portrait_x32y32bd_alpha
								texture = "gfx/interface/base_parts/background_noninteractable_texture.dds"
								alpha = 0.15
								modify_texture = {
									texture = "gfx/interface/base_parts/gradient_black_flip.dds"
									blend_mode = alphamultiply
								}
							}
						}
					}
				}
				widget = {
					size = { 100% 100% }
					textbox = {
						name = "Text"
						position = { 0 -1 }
						widgetanchor = center
						parentanchor = center				
						using = BaseFontS
						using = Default_FontColor
						autoresize = yes
						align = center
						text = "Button Text"
					}
				}
			}
		}
		#widget = {
		#	size = { 100% 100% }
		#	filter_mouse = left|wheel|right
		#}
		#384 - 150
		#256 - 100
		#192 - 75
		#128 - 50

		#upper_strata
		#middle_strata
		#lower_strata
		#proletariat
		#indentured
		#tribesmen
		#slaves
	}
}