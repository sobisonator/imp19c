	type mp_select_country_map_coa = widget {
		size = { 100% 100% }
		widget = {
			size = { 100 100 }
			block "position" { }
			widget = {
				size = { 100% 100% }
				visible = "[Not(EqualTo_string(LobbyView.GetSelectedPlayable.GetCountry.GetTag, Country.GetTag))]"
				alpha = 0.5
				widget = {
					size = { 100% 66% }
					parentanchor = center
					using = background_widget
					visible = "[Not(EqualTo_int32(FixedPointToInt(GuiScope.SetRoot( Country.MakeScope ).ScriptValue('DIPLOMACY_flag_shape') ), '(int32)3'))]"
				}
				widget = {
					size = { 66% 66% }
					parentanchor = center
					using = background_widget
					visible = "[EqualTo_int32(FixedPointToInt(GuiScope.SetRoot( Country.MakeScope ).ScriptValue('DIPLOMACY_flag_shape') ), '(int32)3')]"
				}
				new_country_flag = {
					blockoverride "Size" { size = { 100% 100% } }
					onmousehierarchyenter = "[GetVariableSystem.Set(Country.GetNameWithNoTooltip, 'on')]"
					onmousehierarchyleave = "[GetVariableSystem.Set(Country.GetNameWithNoTooltip, 'off')]"
					blockoverride "On_click" { onclick = "[SetLobbyCountryTag(Country.GetTag)]" }
				}
			}
			widget = {
				size = { 100% 100% }
				visible = "[EqualTo_string(LobbyView.GetSelectedPlayable.GetCountry.GetTag, Country.GetTag)]"
				widget = {
					size = { 100% 66% }
					parentanchor = center
					using = background_widget
					visible = "[Not(EqualTo_int32(FixedPointToInt(GuiScope.SetRoot( Country.MakeScope ).ScriptValue('DIPLOMACY_flag_shape') ), '(int32)3'))]"
				}
				widget = {
					size = { 66% 66% }
					parentanchor = center
					using = background_widget
					visible = "[EqualTo_int32(FixedPointToInt(GuiScope.SetRoot( Country.MakeScope ).ScriptValue('DIPLOMACY_flag_shape') ), '(int32)3')]"
				}
				new_country_flag = {
					blockoverride "Size" { size = { 100% 100% } }
					onmousehierarchyenter = "[GetVariableSystem.Set(Country.GetNameWithNoTooltip, 'on')]"
					onmousehierarchyleave = "[GetVariableSystem.Set(Country.GetNameWithNoTooltip, 'off')]"
				}
			}
		}
