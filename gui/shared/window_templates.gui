					modify_texture = {
						texture = "gfx/interface/base_parts/button_vignette.dds"
						blend_mode = alphamultiply
						spriteType = corneredtiled
						spriteborder = { 20 20 }
					}
				}
				background = {
					shaderfile = "gfx/FX/pdxgui_default.shader"
					using = beige_background
					alpha = 0.3
					modify_texture = {
						texture = "gfx/interface/base_parts/button_vignette.dds"
						blend_mode = alphamultiply
						spriteType = corneredtiled
						spriteborder = { 20 20 }
					}
				}
				background = {
					shaderfile = "gfx/FX/pdxgui_default.shader"
					using = black_background
					alpha = 2.0
					margin = { -3 -3 }
				}
				background = {
					shaderfile = "gfx/FX/pdxgui_default.shader"
					using = beige_background
					alpha = 0.15
					margin = { -3 -3 }
					modify_texture = {
						texture = "gfx/interface/base_parts/gradient_black_flip.dds"
						blend_mode = alphamultiply
					}
				}
			}
		}
		flowcontainer = {
			margin = { 5 0 }
			spacing = 5
			parentanchor = hcenter
			textbox = {
				minimumsize = { 0 40 }
				block "Text" { text = "[Country.GetNameWithNoTooltip]" }
				max_width = 170
				elide = right				
				align = left|nobaseline
				using = BaseFontM
				using = Default_FontColor
				fontsize_min = 14
				autoresize = yes
			}
		}
